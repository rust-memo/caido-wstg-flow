{
  "name": "caido-wstg-flow",
  "version": "1.1.0",
  "private": true,
  "description": "Project-aware OWASP WSTG checklist, passive candidate discovery, evidence verification, and reporting for Caido",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rust-memo/caido-wstg-flow.git"
  },
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./packages/**/src",
    "lint:fix": "eslint ./packages/**/src --fix",
    "knip": "knip",
    "build": "caido-dev build",
    "watch": "caido-dev watch"
  },
  "devDependencies": {
    "@caido-community/dev": "^0.1.7",
    "@caido/eslint-config": "0.10.0",
    "@types/node": "22.20.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "eslint": "9.39.5",
    "happy-dom": "20.10.6",
    "knip": "6.26.0",
    "postcss-prefixwrap": "1.58.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "vue": "3.5.39"
  }
}
